{
  "name": "asset-audit-pro",
  "private": true,
  "version": "1.10.463",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:client": "vite build",
    "build:worker": "vite build --ssr src/server/index.ts",
    "build": "npm run build:client && npm run build:worker",
    "preview": "npm run build && wrangler dev",
    "lint": "tsc --noEmit",
    "deploy": "npm version patch --no-git-tag-version && npm run build && wrangler deploy",
    "release": "npm version patch && npm run deploy",
    "version": "npm run lint",
    "postversion": "git push && git push --tags"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/zod-validator": "^0.7.6",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "hono": "^4.12.10",
    "lucide-react": "^0.575.0",
    "papaparse": "5.4.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.28.0",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^3.101.0"
  }
}
